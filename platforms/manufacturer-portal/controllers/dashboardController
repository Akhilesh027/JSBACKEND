const Manufacturer = require("../models/Manufacturer");
const Product = require("../models/Product");
const Factory = require("../models/Factory");
const mongoose = require("mongoose");


// ==========================
//  SIMPLE DASHBOARD
// ==========================
exports.getDashboardStats = async (req, res) => {
  try {
    const { userId } = req.params;

    if (!mongoose.Types.ObjectId.isValid(userId)) {
      return res.status(400).json({
        success: false,
        message: "Invalid manufacturer ID",
      });
    }

    const manufacturer = await Manufacturer.findById(userId)
      .select("totalCatalogues newOrders factoriesLinked profileCompletion");

    if (!manufacturer) {
      return res.status(404).json({
        success: false,
        message: "Manufacturer not found",
      });
    }

    const dashboardStats = {
      totalCatalogues: manufacturer.totalCatalogues || 0,
      newOrders: manufacturer.newOrders || 0,
      factoriesLinked: manufacturer.factoriesLinked || 0,
      profileStatus: manufacturer.profileCompletion >= 80 ? "Complete" : "Incomplete",
    };

    res.status(200).json({
      success: true,
      data: dashboardStats,
    });

  } catch (error) {
    console.error("Dashboard stats error:", error);
    res.status(500).json({
      success: false,
      message: "Internal server error",
    });
  }
};


// ==========================
//  DETAILED DASHBOARD
// ==========================
exports.getDetailedDashboard = async (req, res) => {
  try {
    const { userId } = req.params;

    if (!mongoose.Types.ObjectId.isValid(userId)) {
      return res.status(400).json({
        success: false,
        message: "Invalid manufacturer ID",
      });
    }

    const manufacturer = await Manufacturer.findById(userId).select(
      "companyName email contact location isVerified status createdAt"
    );

    if (!manufacturer) {
      return res.status(404).json({
        success: false,
        message: "Manufacturer not found",
      });
    }

    // FIXED FIELD NAMES BASED ON YOUR DB
    const [
      totalProducts,
      activeProducts,
      totalFactories,
      activeFactories,
    ] = await Promise.all([
      Product.countDocuments({ manufacturer: userId }),
      Product.countDocuments({
        manufacturer: userId,
        availability: "In Stock"
      }),
      Factory.countDocuments({ manufacturer: userId }),
      Factory.countDocuments({
        manufacturer: userId,
        status: "active"
      }),
    ]);

    // Profile Completion
    const profileFields = [
      manufacturer.companyName,
      manufacturer.email,
      manufacturer.contact,
      manufacturer.location,
    ];

    const completedFields = profileFields.filter(field =>
      field && field.toString().trim().length > 0
    ).length;

    const profileCompletionPercentage = Math.round(
      (completedFields / profileFields.length) * 100
    );

    const dashboardData = {
      manufacturerInfo: {
        id: manufacturer._id,
        companyName: manufacturer.companyName,
        email: manufacturer.email,
        isVerified: manufacturer.isVerified,
        status: manufacturer.status,
        joinedDate: manufacturer.createdAt,
      },
      statistics: {
        products: {
          total: totalProducts,
          active: activeProducts,
          inactive: totalProducts - activeProducts,
        },
        factories: {
          total: totalFactories,
          active: activeFactories,
          inactive: totalFactories - activeFactories,
        },
      },
      profileStatus: {
        percentage: profileCompletionPercentage,
        status: profileCompletionPercentage === 100 ? "Completed" : "Incomplete",
        missingFields: [
          !manufacturer.companyName && "companyName",
          !manufacturer.email && "email",
          !manufacturer.contact && "contact",
          !manufacturer.location && "location",
        ].filter(Boolean),
      },
    };

    res.status(200).json({
      success: true,
      message: "Dashboard loaded successfully",
      data: dashboardData,
      timestamp: new Date().toISOString(),
    });

  } catch (error) {
    console.error("Dashboard API error:", error);
    res.status(500).json({
      success: false,
      message: "Failed to fetch dashboard",
      error: process.env.NODE_ENV === "development" ? error.message : undefined,
    });
  }
};
