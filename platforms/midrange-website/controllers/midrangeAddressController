// controllers/midrangeAddressController.js
const MidrangeAddress = require("../models/MidrangeAddress");

const WEBSITE = "mid_range";

exports.getMyAddresses = async (req, res) => {
  try {
    const userId = req.user.id;

    const addresses = await MidrangeAddress.find({ userId, website: WEBSITE })
      .sort({ isDefault: -1, createdAt: -1 })
      .lean();

    return res.json({ data: addresses });
  } catch (err) {
    return res.status(500).json({ message: err.message || "Server error" });
  }
};

exports.addAddress = async (req, res) => {
  try {
    const userId = req.user.id;
    const {
      fullName,
      phone,
      line1,
      line2,
      landmark,
      city,
      state,
      pincode,
      isDefault,
    } = req.body;

    if (!fullName || !phone || !line1 || !city || !state || !pincode) {
      return res.status(400).json({ message: "Missing required address fields" });
    }

    // if isDefault -> unset previous defaults
    if (isDefault) {
      await MidrangeAddress.updateMany(
        { userId, website: WEBSITE, isDefault: true },
        { $set: { isDefault: false } }
      );
    }

    const created = await MidrangeAddress.create({
      userId,
      website: WEBSITE,
      fullName,
      phone,
      line1,
      line2,
      landmark,
      city,
      state,
      pincode,
      isDefault: !!isDefault,
    });

    return res.json({ data: created, message: "Address saved" });
  } catch (err) {
    return res.status(500).json({ message: err.message || "Server error" });
  }
};

exports.setDefault = async (req, res) => {
  try {
    const userId = req.user.id;
    const { id } = req.params;

    await MidrangeAddress.updateMany(
      { userId, website: WEBSITE, isDefault: true },
      { $set: { isDefault: false } }
    );

    const updated = await MidrangeAddress.findOneAndUpdate(
      { _id: id, userId, website: WEBSITE },
      { $set: { isDefault: true } },
      { new: true }
    ).lean();

    return res.json({ data: updated, message: "Default address updated" });
  } catch (err) {
    return res.status(500).json({ message: err.message || "Server error" });
  }
};
