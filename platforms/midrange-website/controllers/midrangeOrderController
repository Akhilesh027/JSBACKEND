const mongoose = require("mongoose");
const MidRangeCart = require("../models/MidRangeCart");
const MidrangeAddress = require("../models/MidrangeAddress");
const MidrangeOrder = require("../models/MidrangeOrder.js");
const Product = require("../../manufacturer-portal/models/Product");
const Coupon = require("../../Admin/models/Coupon.js");
const CouponUsage = require("../../Admin/models/CouponUsage.js");
// ✅ ADD: midrange customer model (update path/name if different)
const MidrangeCustomer = require("../models/midrange_customers.js");

const WEBSITE = "mid_range";
const ALLOWED_TIER = "mid_range";
const ALLOWED_STATUS = "approved";
const DISCOUNT_PERCENT = 10;

function computeDiscount(price) {
  const discountAmount = Math.round((Number(price || 0) * DISCOUNT_PERCENT) / 100);
  const finalPrice = Number(price || 0) - discountAmount;
  return { discountAmount, finalPrice };
}
exports.placeOrder = async (req, res) => {
  const session = await mongoose.startSession();

  try {
    const userId = req.user.id;
    const {
      addressId,
      paymentMethod = "COD",
      coupon, // ✅ { code, couponId } optional
    } = req.body;

    if (!mongoose.Types.ObjectId.isValid(addressId)) {
      return res.status(400).json({ message: "Invalid addressId" });
    }

    const website = WEBSITE; // your constant
    const now = new Date();

    let createdOrder = null;

    await session.withTransaction(async () => {
      // ✅ 1) Validate Address
      const address = await MidrangeAddress.findOne({
        _id: addressId,
        userId,
        website,
      })
        .lean()
        .session(session);

      if (!address) {
        throw new Error("Address not found");
      }

      // ✅ 2) Load Cart
      const cart = await MidRangeCart.findOne({ userId }).lean().session(session);
      if (!cart || !cart.items || cart.items.length === 0) {
        throw new Error("Cart is empty");
      }

      // ✅ 3) Hydrate Allowed Products
      const productIds = cart.items.map((i) => i.productId);
      const products = await Product.find({
        _id: { $in: productIds },
        tier: ALLOWED_TIER,
        status: ALLOWED_STATUS,
      })
        .lean()
        .session(session);

      const pMap = new Map(products.map((p) => [String(p._id), p]));

      const orderItems = [];
      for (const it of cart.items) {
        const p = pMap.get(String(it.productId));
        if (!p) continue;

        const qty = Math.max(1, Number(it.quantity) || 1);
        const { discountAmount, finalPrice } = computeDiscount(p.price);

        orderItems.push({
          productId: p._id,
          name: p.name,
          image: p.image,
          quantity: qty,
          price: Number(p.price || 0),
          discountPercent: DISCOUNT_PERCENT,
          discountAmount,
          finalPrice,
        });
      }

      if (orderItems.length === 0) {
        throw new Error("No valid mid-range approved products in cart");
      }

      // ✅ 4) Base Totals (before coupon)
      const subtotalBase = orderItems.reduce(
        (s, x) => s + x.finalPrice * x.quantity,
        0
      );

      const shippingBase = subtotalBase > 10000 ? 0 : 499;

      // ✅ 5) Coupon Verification + Discount Calculation (server-truth)
      let couponDoc = null;
      let couponDiscount = 0;
      let shippingDiscount = 0;
      let couponSnapshot = null;

      const couponCodeRaw = coupon?.code ? String(coupon.code) : "";
      const couponCode = couponCodeRaw ? normalizeCode(couponCodeRaw) : "";

      if (couponCode) {
        // IMPORTANT: apply coupon minOrder should be checked on subtotalBase (items total),
        // NOT on finalTotal / not on shipping/tax.
        couponDoc = await Coupon.findOne({
          code: couponCode,
          website: { $in: [website, "all"] },
        })
          .session(session);

        if (!couponDoc) {
          throw new Error("Coupon not found");
        }

        // optional: if couponId sent, ensure it matches
        if (coupon?.couponId && String(couponDoc._id) !== String(coupon.couponId)) {
          throw new Error("Coupon mismatch");
        }

        const computed = computeStatusByDates(couponDoc);

        if (couponDoc.status === "disabled") throw new Error("Coupon is disabled.");
        if (couponDoc.status === "draft") throw new Error("Coupon is not active.");
        if (computed === "expired") throw new Error("Coupon expired.");
        if (computed === "scheduled") throw new Error("Coupon not started yet.");

        // min order
        if (couponDoc.minOrder != null && subtotalBase < Number(couponDoc.minOrder)) {
          throw new Error(
            `Minimum order is ₹${Number(couponDoc.minOrder).toLocaleString("en-IN")}.`
          );
        }

        // total usage limit
        if (couponDoc.totalLimit != null && couponDoc.usedCount >= Number(couponDoc.totalLimit)) {
          throw new Error("Coupon usage limit reached.");
        }

        // per user limit
        if (couponDoc.perUserLimit != null) {
          const usage = await CouponUsage.findOne({
            couponId: couponDoc._id,
            userId,
          })
            .session(session);

          const used = usage?.count || 0;
          if (used >= Number(couponDoc.perUserLimit)) {
            throw new Error("Per-user coupon limit reached.");
          }
        }

        // ✅ calc discount
        const breakdown = calcDiscount({
          coupon: couponDoc,
          cartTotal: subtotalBase,
          shipping: shippingBase,
        });

        couponDiscount = Number(breakdown.discount || 0);
        shippingDiscount = Number(breakdown.shippingDiscount || 0);

        couponSnapshot = {
          couponId: couponDoc._id,
          code: couponDoc.code,
          type: couponDoc.type,
          value: couponDoc.value,
          maxDiscount: couponDoc.maxDiscount,
        };
      }

      // ✅ 6) Final Totals (after coupon)
      const subtotalAfterDiscount = Math.max(0, subtotalBase - couponDiscount);
      const shippingAfterDiscount = Math.max(0, shippingBase - shippingDiscount);

      // tax on (subtotalAfterDiscount + shippingAfterDiscount)
      const tax = Math.round((subtotalAfterDiscount + shippingAfterDiscount) * 0.18);
      const total = subtotalAfterDiscount + shippingAfterDiscount + tax;

      // ✅ Fix "min order ₹10" / "minimum payable" issue:
      // Some payment gateways / business logic may require at least ₹10 payable.
      if (total < 10) {
        throw new Error("Minimum payable amount is ₹10. Please add more items.");
      }

      // ✅ 7) Create Order
      const order = await MidrangeOrder.create(
        [
          {
            userId,
            website,
            items: orderItems,
            addressSnapshot: {
              fullName: address.fullName,
              phone: address.phone,
              line1: address.line1,
              line2: address.line2,
              landmark: address.landmark,
              city: address.city,
              state: address.state,
              pincode: address.pincode,
            },
            totals: {
              subtotal: subtotalBase,
              discount: couponDiscount,
              shippingBase,
              shippingDiscount,
              shipping: shippingAfterDiscount,
              tax,
              total,
            },
            coupon: couponSnapshot, // ✅ store coupon snapshot on order (optional but recommended)
            payment: {
              method: paymentMethod,
              status: "pending",
            },
            status: "placed",
            createdAt: now,
          },
        ],
        { session }
      );

      createdOrder = order[0];

      // ✅ 8) Redeem coupon in same transaction (increment counts)
      if (couponDoc) {
        await Coupon.updateOne(
          { _id: couponDoc._id },
          { $inc: { usedCount: 1 } },
          { session }
        );

        await CouponUsage.updateOne(
          { couponId: couponDoc._id, userId },
          { $inc: { count: 1 }, $setOnInsert: { couponId: couponDoc._id, userId } },
          { upsert: true, session }
        );
      }

      // ✅ 9) Clear Cart
      await MidRangeCart.updateOne(
        { userId },
        { $set: { items: [] } },
        { session }
      );

      // ✅ 10) Update Customer Stats
      await MidrangeCustomer.updateOne(
        { _id: userId },
        {
          $inc: { totalOrders: 1, lifetimeSpend: total },
          $set: { lastOrderDate: now },
        },
        { session }
      );
    });

    return res.json({ data: createdOrder, message: "Order placed successfully" });
  } catch (err) {
    const msg = err?.message || "Server error";

    // match your earlier error styles
    if (msg === "Address not found") return res.status(404).json({ message: msg });
    if (msg === "Cart is empty") return res.status(400).json({ message: msg });
    if (msg.includes("Minimum order is ₹")) return res.status(400).json({ message: msg });
    if (msg.includes("Minimum payable amount is ₹10")) return res.status(400).json({ message: msg });
    if (msg.toLowerCase().includes("coupon")) return res.status(400).json({ message: msg });

    return res.status(500).json({ message: msg });
  } finally {
    session.endSession();
  }
};


exports.getOrderById = async (req, res) => {
  try {
    const userId = req.user.id;
    const { id } = req.params;

    if (!mongoose.Types.ObjectId.isValid(id)) {
      return res.status(400).json({ message: "Invalid order id" });
    }

    const order = await MidrangeOrder.findOne({
      _id: id,
      userId,
      website: WEBSITE,
    }).lean();

    if (!order) return res.status(404).json({ message: "Order not found" });

    return res.json({ data: order });
  } catch (err) {
    return res.status(500).json({ message: err.message || "Server error" });
  }
};

exports.getMyOrders = async (req, res) => {
  try {
    const userId = req.user.id;

    const orders = await MidrangeOrder.find({
      userId,
      website: WEBSITE,
    })
      .sort({ createdAt: -1 })
      .lean();

    return res.json({ data: orders });
  } catch (err) {
    return res.status(500).json({ message: err.message || "Server error" });
  }
};
