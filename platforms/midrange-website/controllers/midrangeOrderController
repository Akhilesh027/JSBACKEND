// controllers/midrangeOrderController.js
const mongoose = require("mongoose");
const crypto = require("crypto");

const MidRangeCart = require("../models/MidRangeCart");
const MidrangeAddress = require("../models/MidrangeAddress");
const MidrangeOrder = require("../models/MidrangeOrder");
const Product = require("../../manufacturer-portal/models/Product");
const Coupon = require("../../Admin/models/Coupon");
const CouponUsage = require("../../Admin/models/CouponUsage");
const MidrangeCustomer = require("../models/midrange_customers");

const WEBSITE = "mid_range";
const ALLOWED_TIER = "mid_range";
const ALLOWED_STATUS = "approved";
const DISCOUNT_PERCENT = 10;

// Helpers (unchanged) ...

function computeDiscount(price) {
  const discountAmount = Math.round((Number(price || 0) * DISCOUNT_PERCENT) / 100);
  const finalPrice = Number(price || 0) - discountAmount;
  return { discountAmount, finalPrice };
}

function normalizeCode(code) {
  return String(code || "").trim().toUpperCase();
}

function computeStatusByDates(couponDoc) {
  const now = new Date();
  const start = couponDoc?.startDate ? new Date(couponDoc.startDate) : null;
  const end = couponDoc?.endDate ? new Date(couponDoc.endDate) : null;
  if (start && now < start) return "scheduled";
  if (end && now > end) return "expired";
  return "active";
}

function calcDiscount({ coupon, cartTotal, shipping }) {
  const type = coupon.type;
  const value = Number(coupon.value || 0);
  let discount = 0;
  let shippingDiscount = 0;
  if (type === "percentage") {
    discount = Math.round((cartTotal * value) / 100);
    if (coupon.maxDiscount != null) discount = Math.min(discount, Number(coupon.maxDiscount));
  } else if (type === "flat") {
    discount = Math.min(value, cartTotal);
  } else if (type === "free_shipping") {
    shippingDiscount = Number(shipping || 0);
  }
  discount = Math.max(0, discount);
  shippingDiscount = Math.max(0, shippingDiscount);
  return { discount, shippingDiscount };
}

function verifyRazorpaySignature({ razorpayOrderId, razorpayPaymentId, razorpaySignature }) {
  if (!razorpayOrderId || !razorpayPaymentId || !razorpaySignature) return false;
  const secret = process.env.RAZORPAY_KEY_SECRET;
  if (!secret) throw new Error("RAZORPAY_KEY_SECRET missing on server");
  const body = `${razorpayOrderId}|${razorpayPaymentId}`;
  const expected = crypto.createHmac("sha256", secret).update(body).digest("hex");
  return expected === razorpaySignature;
}

function isValidObjectId(id) {
  return mongoose.Types.ObjectId.isValid(id);
}

// -----------------------------
// PLACE ORDER (COD + RAZORPAY)
// -----------------------------
exports.placeOrder = async (req, res) => {
  const session = await mongoose.startSession();
  try {
    const userId = req.user?.id;
    const {
      addressId,
      paymentMethod = "COD",
      coupon,
      payment,
    } = req.body || {};

    if (!userId) return res.status(401).json({ message: "Unauthorized" });
    if (!isValidObjectId(addressId)) {
      return res.status(400).json({ message: "Invalid addressId" });
    }

    const pm = String(paymentMethod || "COD").toUpperCase();
    if (!["COD", "RAZORPAY"].includes(pm)) {
      return res.status(400).json({ message: "Invalid paymentMethod" });
    }

    const website = WEBSITE;
    const now = new Date();
    let createdOrder = null;

    await session.withTransaction(async () => {
      let payStatus = "pending";
      let gateway = "";
      let razorpayInfo = null;

      if (pm === "RAZORPAY") {
        gateway = "razorpay";
        razorpayInfo = {
          razorpayOrderId: payment?.razorpayOrderId,
          razorpayPaymentId: payment?.razorpayPaymentId,
          razorpaySignature: payment?.razorpaySignature,
        };
        if (!razorpayInfo.razorpayOrderId || !razorpayInfo.razorpayPaymentId || !razorpayInfo.razorpaySignature) {
          throw new Error("Razorpay payment details missing");
        }
        const existing = await MidrangeOrder.findOne({
          userId,
          website,
          "payment.razorpayPaymentId": razorpayInfo.razorpayPaymentId,
          "payment.status": "paid",
        }).lean().session(session);
        if (existing) {
          createdOrder = existing;
          return;
        }
        const ok = verifyRazorpaySignature(razorpayInfo);
        if (!ok) throw new Error("Invalid Razorpay payment");
        payStatus = "paid";
      }

      // 1) Validate Address
      const address = await MidrangeAddress.findOne({ _id: addressId, userId, website }).lean().session(session);
      if (!address) throw new Error("Address not found");

      // 2) Load Cart
      const cart = await MidRangeCart.findOne({ userId }).lean().session(session);
      if (!cart?.items?.length) throw new Error("Cart is empty");

      // 3) Hydrate Allowed Products
      const productIds = cart.items.map((i) => i.productId).filter(Boolean);
      const products = await Product.find({
        _id: { $in: productIds },
        tier: ALLOWED_TIER,
        status: ALLOWED_STATUS,
      }).lean().session(session);
      const pMap = new Map(products.map((p) => [String(p._id), p]));

      const orderItems = [];
      for (const it of cart.items) {
        const p = pMap.get(String(it.productId));
        if (!p) continue;
        const qty = Math.max(1, Number(it.quantity) || 1);
        const { discountAmount, finalPrice } = computeDiscount(p.price);

        orderItems.push({
          productId: p._id,
          variantId: it.variantId || null,                    // ✅ copy variantId
          attributes: it.attributes || {},                      // ✅ copy attributes
          name: p.name || "",
          image: p.image || "",
          quantity: qty,
          price: Number(p.price || 0),
          discountPercent: DISCOUNT_PERCENT,
          discountAmount,
          finalPrice,
        });
      }
      if (orderItems.length === 0) {
        throw new Error("No valid mid-range approved products in cart");
      }

      // 4) Base Totals (before coupon)
      const subtotalBase = orderItems.reduce((s, x) => s + x.finalPrice * x.quantity, 0);
      const shippingBase = subtotalBase > 10000 ? 0 : 499;

      // 5) Coupon Verification + Discount Calculation
      let couponDoc = null;
      let couponDiscount = 0;
      let shippingDiscount = 0;
      let couponSnapshot = null;

      const couponCodeRaw = coupon?.code ? String(coupon.code) : "";
      const couponCode = couponCodeRaw ? normalizeCode(couponCodeRaw) : "";

      if (couponCode) {
        couponDoc = await Coupon.findOne({
          code: couponCode,
          website: { $in: [website, "all"] },
        }).session(session);
        if (!couponDoc) throw new Error("Coupon not found");
        if (coupon?.couponId && String(couponDoc._id) !== String(coupon.couponId)) {
          throw new Error("Coupon mismatch");
        }
        const computedStatus = computeStatusByDates(couponDoc);
        if (couponDoc.status === "disabled") throw new Error("Coupon is disabled.");
        if (couponDoc.status === "draft") throw new Error("Coupon is not active.");
        if (computedStatus === "expired") throw new Error("Coupon expired.");
        if (computedStatus === "scheduled") throw new Error("Coupon not started yet.");
        if (couponDoc.minOrder != null && subtotalBase < Number(couponDoc.minOrder)) {
          throw new Error(`Minimum order is ₹${Number(couponDoc.minOrder).toLocaleString("en-IN")}.`);
        }
        if (couponDoc.totalLimit != null && couponDoc.usedCount >= Number(couponDoc.totalLimit)) {
          throw new Error("Coupon usage limit reached.");
        }
        if (couponDoc.perUserLimit != null) {
          const usage = await CouponUsage.findOne({ couponId: couponDoc._id, userId }).session(session);
          const used = usage?.count || 0;
          if (used >= Number(couponDoc.perUserLimit)) {
            throw new Error("Per-user coupon limit reached.");
          }
        }
        const breakdown = calcDiscount({ coupon: couponDoc, cartTotal: subtotalBase, shipping: shippingBase });
        couponDiscount = Number(breakdown.discount || 0);
        shippingDiscount = Number(breakdown.shippingDiscount || 0);
        couponSnapshot = {
          couponId: couponDoc._id,
          code: couponDoc.code,
          type: couponDoc.type,
          value: couponDoc.value,
          maxDiscount: couponDoc.maxDiscount,
        };
      }

      // 6) Final Totals (after coupon)
      const subtotalAfterDiscount = Math.max(0, subtotalBase - couponDiscount);
      const shippingAfterDiscount = Math.max(0, shippingBase - shippingDiscount);
      const tax = Math.round((subtotalAfterDiscount + shippingAfterDiscount) * 0.18);
      const total = subtotalAfterDiscount + shippingAfterDiscount + tax;
      if (total < 10) {
        throw new Error("Minimum payable amount is ₹10. Please add more items.");
      }

      const shouldFinalize = pm === "COD" || payStatus === "paid";

      // 7) Create Order
      const [orderDoc] = await MidrangeOrder.create(
        [
          {
            userId,
            website,
            items: orderItems,                                   // ✅ now includes variantId & attributes
            addressSnapshot: {
              fullName: address.fullName,
              phone: address.phone,
              line1: address.line1,
              line2: address.line2,
              landmark: address.landmark,
              city: address.city,
              state: address.state,
              pincode: address.pincode,
            },
            totals: {
              subtotal: subtotalBase,
              discount: couponDiscount,
              shippingBase,
              shippingDiscount,
              shipping: shippingAfterDiscount,
              tax,
              total,
            },
            coupon: couponSnapshot || undefined,
            payment: {
              method: pm,
              status: payStatus,
              gateway,
              ...(razorpayInfo || {}),
            },
            status: shouldFinalize ? "placed" : "pending_payment",
            createdAt: now,
          },
        ],
        { session }
      );

      createdOrder = orderDoc;

      // 8) Finalize (coupon redeem + clear cart + customer stats) only when paid/COD
      if (shouldFinalize) {
        if (couponDoc) {
          await Coupon.updateOne({ _id: couponDoc._id }, { $inc: { usedCount: 1 } }, { session });
          await CouponUsage.updateOne(
            { couponId: couponDoc._id, userId },
            { $inc: { count: 1 }, $setOnInsert: { couponId: couponDoc._id, userId } },
            { upsert: true, session }
          );
        }
        await MidRangeCart.updateOne({ userId }, { $set: { items: [] } }, { session });
        await MidrangeCustomer.updateOne(
          { _id: userId },
          { $inc: { totalOrders: 1, lifetimeSpend: total }, $set: { lastOrderDate: now } },
          { session }
        );
      }
    });

    return res.json({ data: createdOrder, message: "Order placed successfully" });
  } catch (err) {
    const msg = err?.message || "Server error";
    if (msg === "Address not found") return res.status(404).json({ message: msg });
    if (msg === "Cart is empty") return res.status(400).json({ message: msg });
    if (msg.includes("Minimum order is ₹")) return res.status(400).json({ message: msg });
    if (msg.includes("Minimum payable amount is ₹10")) return res.status(400).json({ message: msg });
    if (msg.toLowerCase().includes("coupon")) return res.status(400).json({ message: msg });
    if (msg.toLowerCase().includes("razorpay")) return res.status(400).json({ message: msg });
    if (msg.toLowerCase().includes("unauthorized")) return res.status(401).json({ message: msg });
    return res.status(500).json({ message: msg });
  } finally {
    session.endSession();
  }
};

exports.getOrderById = async (req, res) => {
  try {
    const userId = req.user?.id;
    const { id } = req.params;
    if (!userId) return res.status(401).json({ message: "Unauthorized" });
    if (!mongoose.Types.ObjectId.isValid(id)) {
      return res.status(400).json({ message: "Invalid order id" });
    }
    const order = await MidrangeOrder.findOne({ _id: id, userId, website: WEBSITE }).lean();
    if (!order) return res.status(404).json({ message: "Order not found" });
    return res.json({ data: order });
  } catch (err) {
    return res.status(500).json({ message: err.message || "Server error" });
  }
};

exports.getMyOrders = async (req, res) => {
  try {
    const userId = req.user?.id;
    if (!userId) return res.status(401).json({ message: "Unauthorized" });
    const orders = await MidrangeOrder.find({ userId, website: WEBSITE }).sort({ createdAt: -1 }).lean();
    return res.json({ data: orders });
  } catch (err) {
    return res.status(500).json({ message: err.message || "Server error" });
  }
};