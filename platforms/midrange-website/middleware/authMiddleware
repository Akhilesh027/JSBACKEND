const jwt = require('jsonwebtoken');
const Customer = require('../models/midrange_customers');

const midrangeAuthMiddleware = async (req, res, next) => {
  try {
    // Get token from header
    const token = req.header('Authorization')?.replace('Bearer ', '');
    
    if (!token) {
      return res.status(401).json({
        success: false,
        message: 'Authentication required'
      });
    }

    // Verify token
    const decoded = jwt.verify(token, process.env.JWT_SECRET);
    
    // Check if it's a mid-range platform token
    if (decoded.platform !== 'midrange') {
      return res.status(403).json({
        success: false,
        message: 'Invalid platform token'
      });
    }

    // Find customer
    const customer = await Customer.findOne({
      _id: decoded.id,
      email: decoded.email,
      platform: 'midrange',
      isActive: true
    });

    if (!customer) {
      return res.status(401).json({
        success: false,
        message: 'Customer not found or account is inactive'
      });
    }

    // Add customer to request object
    req.customer = customer;
    req.user = {
      id: customer._id,
      email: customer.email,
      role: customer.role,
      platform: customer.platform,
      membershipLevel: customer.membershipLevel
    };
    
    next();
  } catch (error) {
    console.error('Mid-range auth middleware error:', error);
    
    if (error.name === 'JsonWebTokenError') {
      return res.status(401).json({
        success: false,
        message: 'Invalid token'
      });
    }
    
    if (error.name === 'TokenExpiredError') {
      return res.status(401).json({
        success: false,
        message: 'Token expired'
      });
    }
    
    res.status(500).json({
      success: false,
      message: 'Authentication error'
    });
  }
};

module.exports = midrangeAuthMiddleware;